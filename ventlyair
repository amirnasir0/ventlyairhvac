<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vently Air | #1 HVAC Companies Near You | Free Estimate</title>
<meta name="description" content="Vently Air is a top-rated HVAC & air quality company near you. Duct cleaning, furnace service, dryer vent & more. 20,000+ happy clients. Free estimate today.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>
:root {
  --navy:       #0F2645;
  --navy-mid:   #162F52;
  --navy-light: #1D3D66;
  --navy-deep:  #091929;
  --cyan:       #29ABE2;
  --cyan-light: #4DBFF0;
  --cyan-glow:  rgba(41,171,226,0.15);
  --cyan-faint: rgba(41,171,226,0.07);
  --white:      #FFFFFF;
  --off-white:  #F4F8FC;
  --gray-100:   #E8EFF7;
  --gray-400:   #8BA3C0;
  --gray-600:   #4A6785;
  --gold:       #F5A623;
  --green:      #22C55E;
  --text-dark:  #0A1E35;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--white);
  color: var(--text-dark);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ── ANIMATIONS ─────────────────────────────── */
@keyframes fadeUp   { from { opacity:0; transform:translateY(28px) } to { opacity:1; transform:translateY(0) } }
@keyframes fadeIn   { from { opacity:0 } to { opacity:1 } }
@keyframes pulse    { 0%,100%{transform:scale(1);opacity:.6} 70%{transform:scale(1.6);opacity:0} }
@keyframes ticker   { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
@keyframes breathe  { 0%,100%{opacity:.6;transform:scale(1)} 50%{opacity:1;transform:scale(1.03)} }
@keyframes ripple   { 0%{box-shadow:0 0 0 0 rgba(41,171,226,.4)} 100%{box-shadow:0 0 0 18px rgba(41,171,226,0)} }
@keyframes float    { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-7px)} }
@keyframes spin-slow{ from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

/* ── STICKY HEADER ───────────────────────────── */
.hdr {
  position: fixed; top:0; left:0; right:0; z-index:200;
  background: rgba(9,25,41,0.97);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(41,171,226,0.18);
  padding: 0 24px;
  height: 64px;
  display: flex; align-items: center; justify-content: space-between;
  animation: fadeIn .4s ease;
}
.hdr-logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.hdr-logo img { height: 34px; width: auto; mix-blend-mode: screen; }
.hdr-logo-tag {
  font-size: 11px; font-weight: 700; color: var(--cyan);
  letter-spacing: 1.5px; text-transform: uppercase;
  border-left: 1px solid rgba(41,171,226,.3);
  padding-left: 10px; margin-left: 2px;
  display: none;
}
.hdr-right { display: flex; align-items: center; gap: 14px; }
.hdr-rating {
  display: flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--gray-400);
  white-space: nowrap;
}
.hdr-stars { color: var(--gold); font-size: 12px; letter-spacing: 1px; }
.hdr-phone {
  display: flex; align-items: center; gap: 8px;
  background: var(--cyan); color: white;
  padding: 9px 18px; border-radius: 7px;
  font-weight: 700; font-size: 15px;
  text-decoration: none; transition: all .2s;
  white-space: nowrap;
}
.hdr-phone:hover { background: var(--cyan-light); transform: translateY(-1px); }
.hdr-phone svg { width:16px; height:16px; fill:white; flex-shrink:0; }

/* ── HERO ─────────────────────────────────────── */
.hero {
  min-height: 100vh; padding-top: 64px;
  background: var(--navy-deep);
  position: relative; overflow: hidden;
  display: flex; align-items: center;
}
/* animated mesh background */
.hero-mesh {
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 90% 70% at 65% 35%, rgba(41,171,226,0.14) 0%, transparent 55%),
    radial-gradient(ellipse 50% 50% at 10% 80%, rgba(15,38,69,0.7) 0%, transparent 60%),
    radial-gradient(ellipse 40% 60% at 90% 80%, rgba(41,171,226,0.05) 0%, transparent 50%),
    linear-gradient(155deg, #091929 0%, #0F2645 40%, #081520 100%);
}
/* subtle grid */
.hero-grid {
  position:absolute; inset:0; pointer-events:none;
  background-image:
    linear-gradient(rgba(41,171,226,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(41,171,226,0.05) 1px, transparent 1px);
  background-size: 48px 48px;
}
/* floating orb */
.hero-orb {
  position:absolute; right: -80px; top: 10%;
  width: 520px; height: 520px; border-radius: 50%;
  border: 1px solid rgba(41,171,226,0.1);
  animation: breathe 6s ease infinite;
  pointer-events: none;
}
.hero-orb::before {
  content:''; position:absolute; inset: 40px; border-radius:50%;
  border: 1px solid rgba(41,171,226,0.08);
}
.hero-orb::after {
  content:''; position:absolute; inset: 80px; border-radius:50%;
  border: 1px solid rgba(41,171,226,0.06);
}

.hero-inner {
  position:relative; z-index:2;
  max-width: 1200px; margin: 0 auto;
  padding: 60px 24px 80px;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 56px; align-items: center;
  width: 100%;
}

/* left */
.hero-left { animation: fadeUp .7s ease both; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(41,171,226,0.1);
  border: 1px solid rgba(41,171,226,0.25);
  border-radius: 100px; padding: 6px 16px;
  font-size: 12px; font-weight: 700; color: var(--cyan);
  letter-spacing: 1.5px; text-transform: uppercase;
  margin-bottom: 22px;
}
.live-dot {
  width: 7px; height: 7px; background: var(--green); border-radius: 50%;
  position: relative;
}
.live-dot::after {
  content:''; position:absolute; inset:-3px; border-radius:50%;
  border: 2px solid var(--green); animation: pulse 2s ease infinite;
}
.hero-h1 {
  font-family: 'Sora', sans-serif; font-weight: 800;
  font-size: clamp(44px, 5.5vw, 74px);
  line-height: 1.07; letter-spacing: -1.5px;
  color: var(--white); margin-bottom: 22px;
}
.hero-h1 .accent { color: var(--cyan); }
.hero-h1 .ghost {
  -webkit-text-stroke: 1.5px rgba(41,171,226,0.35);
  color: transparent;
}
.hero-sub {
  font-size: 18px; line-height: 1.7;
  color: rgba(255,255,255,0.62); font-weight: 300;
  max-width: 480px; margin-bottom: 32px;
}
.hero-sub strong { color: var(--white); font-weight: 600; }
.hero-chips {
  display: flex; flex-wrap: wrap; gap: 9px; margin-bottom: 36px;
}
.chip {
  display: flex; align-items: center; gap: 6px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 100px; padding: 6px 14px;
  font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.8);
}
.hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
.btn-cyan {
  display: inline-flex; align-items: center; gap: 9px;
  background: var(--cyan); color: white;
  padding: 15px 30px; border-radius: 9px;
  font-weight: 700; font-size: 16px; text-decoration: none;
  border: none; cursor: pointer;
  transition: all .25s; white-space: nowrap;
  animation: ripple 2.5s ease infinite;
}
.btn-cyan:hover { background: var(--cyan-light); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(41,171,226,0.35); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: 9px;
  background: transparent; color: white;
  padding: 15px 28px; border-radius: 9px;
  font-weight: 600; font-size: 16px; text-decoration: none;
  border: 1.5px solid rgba(255,255,255,0.2);
  cursor: pointer; transition: all .25s; white-space: nowrap;
}
.btn-ghost:hover { border-color: var(--cyan); color: var(--cyan); transform: translateY(-2px); }

/* ── HERO FORM ───────────────────────────────── */
.hero-card {
  background: white; border-radius: 18px; overflow: hidden;
  box-shadow: 0 32px 80px rgba(0,0,0,.45), 0 0 0 1px rgba(255,255,255,.04);
  animation: fadeUp .85s .18s ease both;
}
.card-head {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
  border-bottom: 3px solid var(--cyan);
  padding: 22px 28px; text-align: center;
}
.card-head h3 {
  font-family: 'Sora', sans-serif; font-weight: 800;
  font-size: 22px; color: white; letter-spacing: -.3px;
}
.card-head p { font-size: 13px; color: rgba(255,255,255,0.7); margin-top: 5px; }
.card-head-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(41,171,226,0.15); border: 1px solid rgba(41,171,226,.3);
  border-radius: 100px; padding: 4px 12px;
  font-size: 11px; font-weight: 700; color: var(--cyan);
  letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px;
}
.card-body { padding: 24px 26px 26px; }
.f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
.f-group { margin-bottom: 12px; }
.f-group label {
  display:block; font-size:11px; font-weight:700; color:#374151;
  letter-spacing:.6px; text-transform:uppercase; margin-bottom:5px;
}
.f-group input, .f-group select, .f-group textarea {
  width:100%; padding:11px 13px;
  border: 1.5px solid #E5E7EB; border-radius: 7px;
  font-family: 'Plus Jakarta Sans', sans-serif; font-size:14px; color:#111827;
  background: #FAFBFC; outline:none; transition: border .2s;
}
.f-group input:focus, .f-group select:focus, .f-group textarea:focus {
  border-color: var(--cyan); background: white;
}
.f-group textarea { resize:none; height:72px; }
.card-submit {
  width:100%; padding:15px;
  background: var(--navy); color:white; border:none; border-radius:8px;
  font-family:'Sora',sans-serif; font-weight:800; font-size:17px;
  letter-spacing:.3px; cursor:pointer; transition: all .25s;
  display:flex; align-items:center; justify-content:center; gap:8px;
}
.card-submit:hover { background: var(--cyan); transform: translateY(-2px); }
.card-note {
  text-align:center; font-size:11.5px; color:#9CA3AF;
  margin-top:10px; display:flex; align-items:center; justify-content:center; gap:5px;
}

/* ── TICKER ─────────────────────────────────── */
.ticker { background: var(--cyan); padding: 10px 0; overflow:hidden; white-space:nowrap; }
.t-inner { display:inline-flex; animation: ticker 24s linear infinite; }
.t-item {
  display:inline-flex; align-items:center; gap:10px;
  font-weight:700; font-size:13px; letter-spacing:1px; text-transform:uppercase;
  color:white; padding:0 36px;
}
.t-dot { width:4px; height:4px; background:rgba(255,255,255,.5); border-radius:50%; }

/* ── STATS ROW ───────────────────────────────── */
.stats-row {
  background: var(--off-white);
  border-bottom: 1px solid var(--gray-100);
  padding: 0 24px;
}
.stats-inner {
  max-width:1200px; margin:0 auto;
  display: grid; grid-template-columns: repeat(4,1fr);
}
.stat-col {
  padding: 28px 20px; text-align:center;
  border-right: 1px solid var(--gray-100);
  transition: background .2s;
}
.stat-col:last-child { border-right:none; }
.stat-col:hover { background: white; }
.stat-num {
  font-family:'Sora',sans-serif; font-weight:800; font-size:36px;
  color: var(--navy); line-height:1; margin-bottom:4px;
}
.stat-num span { color: var(--cyan); }
.stat-lbl { font-size:13px; color: var(--gray-600); font-weight:500; }
.stat-stars { color: var(--gold); font-size:13px; margin-bottom:6px; }

/* ── SHARED SECTION ──────────────────────────── */
.sec { padding: 88px 24px; }
.sec-inner { max-width:1200px; margin:0 auto; }
.sec-tag {
  display:inline-flex; align-items:center; gap:8px;
  font-size:11px; font-weight:800; color: var(--cyan);
  letter-spacing:2px; text-transform:uppercase; margin-bottom:14px;
}
.sec-tag::before { content:''; width:20px; height:2px; background:var(--cyan); }
.sec-h2 {
  font-family:'Sora',sans-serif; font-weight:800;
  font-size: clamp(34px, 4vw, 52px); letter-spacing:-1px; line-height:1.1;
  color: var(--navy); margin-bottom:14px;
}
.sec-h2 span { color: var(--cyan); }
.sec-sub { font-size:17px; color:var(--gray-600); line-height:1.75; max-width:520px; font-weight:300; }

/* ── SERVICES ─────────────────────────────────── */
.services-bg { background: var(--white); }
.srv-grid {
  display:grid; grid-template-columns: repeat(3,1fr); gap:20px; margin-top:48px;
}
.srv-card {
  border: 1.5px solid var(--gray-100); border-radius:14px;
  padding: 30px 26px; background: white;
  transition: all .3s; cursor:default; position:relative; overflow:hidden;
}
.srv-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background: linear-gradient(90deg, var(--cyan), var(--navy));
  transform:scaleX(0); transition: transform .35s; transform-origin:left;
}
.srv-card:hover { border-color: var(--cyan); transform: translateY(-5px); box-shadow: 0 16px 40px rgba(41,171,226,.12); }
.srv-card:hover::before { transform:scaleX(1); }
.srv-icon { font-size:34px; margin-bottom:14px; display:block; animation: float 5s ease-in-out infinite; }
.srv-card:nth-child(2) .srv-icon { animation-delay:.5s }
.srv-card:nth-child(3) .srv-icon { animation-delay:1s }
.srv-card:nth-child(4) .srv-icon { animation-delay:1.5s }
.srv-card:nth-child(5) .srv-icon { animation-delay:2s }
.srv-card:nth-child(6) .srv-icon { animation-delay:2.5s }
.srv-name { font-family:'Sora',sans-serif; font-weight:700; font-size:17px; color:var(--navy); margin-bottom:8px; }
.srv-desc { font-size:14px; color:var(--gray-600); line-height:1.65; }

/* ── WHY US ───────────────────────────────────── */
.why-bg { background: var(--navy-deep); }
.why-layout { display:grid; grid-template-columns:1fr 1fr; gap:72px; align-items:center; }
.why-list { display:flex; flex-direction:column; gap:20px; }
.why-item {
  display:flex; gap:18px; align-items:flex-start;
  padding:22px; border-radius:12px;
  background:rgba(255,255,255,0.04);
  border:1px solid rgba(255,255,255,.06);
  transition:all .3s;
}
.why-item:hover { background:rgba(41,171,226,.07); border-color:rgba(41,171,226,.22); }
.why-icon {
  width:46px; height:46px; min-width:46px; border-radius:10px;
  background: rgba(41,171,226,0.12); border:1px solid rgba(41,171,226,.25);
  display:flex; align-items:center; justify-content:center; font-size:20px;
  transition: background .3s;
}
.why-item:hover .why-icon { background: var(--cyan); }
.why-title { font-family:'Sora',sans-serif; font-weight:700; font-size:16px; color:white; margin-bottom:5px; }
.why-text { font-size:14px; color:var(--gray-400); line-height:1.65; }
/* big stat panel */
.why-panel { display:flex; flex-direction:column; gap:18px; }
.wp-main {
  background: linear-gradient(135deg, var(--cyan) 0%, #1E8FC4 100%);
  border-radius:16px; padding:36px 32px;
}
.wp-main-num { font-family:'Sora',sans-serif; font-weight:800; font-size:68px; color:white; line-height:1; }
.wp-main-lbl { font-size:16px; color:rgba(255,255,255,.82); font-weight:500; margin-top:6px; }
.wp-row { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
.wp-mini {
  background: rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.07);
  border-radius:12px; padding:22px 18px;
}
.wp-mini-num { font-family:'Sora',sans-serif; font-weight:800; font-size:36px; color:white; }
.wp-mini-lbl { font-size:13px; color:var(--gray-400); margin-top:4px; }

/* ── REVIEWS ─────────────────────────────────── */
.reviews-bg { background: var(--off-white); }
.rev-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-top:48px; }
.rev-card {
  background:white; border:1.5px solid var(--gray-100); border-radius:14px;
  padding:26px; transition:all .3s;
}
.rev-card:hover { transform:translateY(-4px); box-shadow:0 12px 32px rgba(41,171,226,.1); border-color:rgba(41,171,226,.2); }
.rev-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.rev-stars { color:var(--gold); font-size:16px; letter-spacing:1.5px; }
.google-g {
  width:28px; height:28px; border-radius:50%; background:#F5F5F5;
  display:flex; align-items:center; justify-content:center;
  font-size:13px; font-weight:900; color:#4285F4;
}
.rev-text { font-size:14px; line-height:1.75; color:#4B5563; margin-bottom:18px; font-style:italic; }
.rev-author { display:flex; align-items:center; gap:10px; }
.rev-av {
  width:38px; height:38px; border-radius:50%;
  background: linear-gradient(135deg, var(--navy), var(--navy-light));
  border: 2px solid rgba(41,171,226,.3);
  display:flex; align-items:center; justify-content:center;
  font-weight:700; font-size:14px; color:var(--cyan);
}
.rev-name { font-weight:700; font-size:14px; color:var(--navy); }
.rev-loc { font-size:12px; color:var(--gray-600); display:flex; align-items:center; gap:4px; margin-top:2px; }
.verified { color:var(--green); font-size:11px; }

/* ── PROCESS ─────────────────────────────────── */
.process-bg { background: white; }
.steps { display:grid; grid-template-columns:repeat(4,1fr); gap:0; margin-top:56px; position:relative; }
.steps::before {
  content:''; position:absolute; top:34px; left:12.5%; right:12.5%;
  height:2px; background:linear-gradient(90deg, var(--cyan), rgba(41,171,226,.1));
  z-index:0;
}
.step { text-align:center; padding:0 18px; position:relative; z-index:1; }
.step-ring {
  width:68px; height:68px; border-radius:50%;
  border:2.5px solid var(--cyan); background:white;
  display:flex; align-items:center; justify-content:center;
  font-family:'Sora',sans-serif; font-weight:800; font-size:24px; color:var(--cyan);
  margin:0 auto 20px; transition:all .35s;
}
.step:hover .step-ring { background:var(--cyan); color:white; }
.step-t { font-family:'Sora',sans-serif; font-weight:700; font-size:16px; color:var(--navy); margin-bottom:8px; }
.step-d { font-size:13px; color:var(--gray-600); line-height:1.65; }

/* ── LOCATIONS ───────────────────────────────── */
.loc-bg { background: var(--navy-deep); }
.loc-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-top:44px; flex-wrap:wrap; }
.loc-card {
  background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);
  border-radius:12px; padding:20px 16px; text-align:center;
  transition:all .3s; cursor:default;
}
.loc-card:hover { background:rgba(41,171,226,.1); border-color:rgba(41,171,226,.3); transform:translateY(-3px); }
.loc-flag { font-size:28px; margin-bottom:8px; display:block; }
.loc-name { font-weight:700; font-size:14px; color:white; }
.loc-cities { font-size:12px; color:var(--gray-400); margin-top:3px; }

/* ── BOTTOM FORM ─────────────────────────────── */
.form-sec { background: var(--off-white); }
.form-sec-inner { max-width:680px; margin:0 auto; text-align:center; }
.big-form {
  background:white; border:1.5px solid var(--gray-100);
  border-radius:18px; padding:38px; margin-top:38px; text-align:left;
  box-shadow: 0 8px 40px rgba(41,171,226,.08);
}
.big-form .f-row { grid-template-columns:1fr 1fr; }
.big-submit {
  width:100%; padding:16px;
  background: var(--navy); color:white; border:none; border-radius:9px;
  font-family:'Sora',sans-serif; font-weight:800; font-size:18px;
  cursor:pointer; transition:all .25s;
  display:flex; align-items:center; justify-content:center; gap:8px;
}
.big-submit:hover { background:var(--cyan); transform:translateY(-2px); box-shadow:0 10px 30px rgba(41,171,226,.3); }

/* ── FAQ ──────────────────────────────────────── */
.faq-bg { background: white; }
.faq-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:46px; }
.faq-item {
  border:1.5px solid var(--gray-100); border-radius:12px; overflow:hidden;
  transition:border-color .3s;
}
.faq-item:hover { border-color:rgba(41,171,226,.3); }
.faq-q {
  display:flex; align-items:center; justify-content:space-between; gap:12px;
  padding:20px 22px; cursor:pointer; user-select:none;
}
.faq-q-txt { font-weight:600; font-size:15px; color:var(--navy); flex:1; line-height:1.4; }
.faq-ico {
  width:28px; height:28px; min-width:28px; border-radius:50%;
  background:rgba(41,171,226,.08); border:1px solid rgba(41,171,226,.2);
  display:flex; align-items:center; justify-content:center;
