<script>
function toggleFaq(el) {
  const item = el.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

function submitForm(which) {
  const bodyId = which === 'hero' ? 'hero-form-body' : 'bottom-form-body';
  const successId = which === 'hero' ? 'hero-success' : 'bottom-success';
  document.getElementById(bodyId).style.display = 'none';
  const s = document.getElementById(successId);
  s.style.display = 'block';
  s.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

// Scroll reveal
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.style.opacity = '1';
      e.target.style.transform = 'translateY(0)';
    }
  });
}, { threshold: 0.08 });

document.querySelectorAll('.srv-card, .why-item, .rev-card, .step, .stat-col, .faq-item, .loc-card').forEach((el, i) => {
  el.style.opacity = '0';
  el.style.transform = 'translateY(22px)';
  el.style.transition = `opacity .5s ${i * 0.07}s ease, transform .5s ${i * 0.07}s ease`;
  observer.observe(el);
});

// Smooth scroll for anchor links
document.querySelectorAll('a[href="#get-estimate"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById('get-estimate').scrollIntoView({ behavior: 'smooth' });
  });
});
</script>

